# Cổng server
PORT=8080

# === DATABASE ===
# Để TRỐNG = dùng SQLite (dev local, file data/tlx.db)
# Điền vào = dùng PostgreSQL (production VPS)
# DATABASE_URL=postgres://tlx:matkhau@localhost:5432/tlx
DATABASE_URL=
PG_POOL_MAX=20
DATA_DIR=./data

# === BẢO MẬT (QUAN TRỌNG cho production) ===
# Khoá bí mật để mã hoá cookie Zalo trong DB. BẮT BUỘC đặt khi lên production.
# Tạo: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
APP_SECRET=
# Độ mạnh bcrypt (10-12 hợp lý; cao hơn = chậm hơn nhưng an toàn hơn)
BCRYPT_ROUNDS=10

# CORS: domain frontend (production ghi rõ thay vì *)
CORS_ORIGIN=*

# Debug tin nhắn thô
DEBUG_RAW=false

# Độ trễ ngẫu nhiên trước khi gửi "Ok"
OK_DELAY_MIN=400
OK_DELAY_MAX=1200
