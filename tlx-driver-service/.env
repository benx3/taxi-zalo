# Driver Service — port riêng, dùng chung SQLite với tlx-worker
PORT=8080

# Trỏ tới cùng file DB với tlx-worker (để dùng chung dữ liệu user/session)
DATA_DIR=../tlx-worker/data

# Production: đặt DATABASE_URL nếu dùng PostgreSQL
# DATABASE_URL=postgres://user:pass@host/dbname

# CORS
# CORS_ORIGIN=https://driver.yourdomain.com
